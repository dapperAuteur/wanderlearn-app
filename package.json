    "marked": "^18.0.0",
    "next": "16.2.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.3",
    "serwist": "^9.5.7",
    "stripe": "^18.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
