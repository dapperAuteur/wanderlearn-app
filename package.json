    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test:a11y": "playwright test",
    "test:a11y:seeded": "PLAYWRIGHT_SEEDED=1 playwright test",
    "test:pa11y": "pa11y-ci",
    "a11y": "pnpm test:a11y",
    "a11y:seeded": "pnpm test:a11y:seeded && pnpm test:pa11y"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.2",
