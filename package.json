    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "csv-parse": "^6.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "pa11y-ci": "^4.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
