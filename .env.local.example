# ==============================================================================
# Wanderlearn — environment variables
#
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# See docs/NEON_SETUP.md for step-by-step provisioning instructions.
# ==============================================================================

# ---- Next.js / app ----------------------------------------------------------
# Do NOT set NODE_ENV yourself. Next.js and Vercel set it automatically
# (development in dev, production in build/prod). Overriding it triggers
# the "non-standard NODE_ENV" warning and breaks some internals.
NEXT_PUBLIC_APP_NAME=Wanderlearn
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ---- Database (Neon Postgres) -----------------------------------------------
# Create a project at https://neon.tech and copy the pooled connection string.
# Format: postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# ---- Better Auth ------------------------------------------------------------
# BETTER_AUTH_SECRET: a 32+ character random string. Generate one with:
#   openssl rand -base64 48
# BETTER_AUTH_URL: the public base URL of the app (no trailing slash).
# For passkeys to work in production, this must be HTTPS and match the
# domain the browser sees.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---- Email (Mailgun) --------------------------------------------------------
# Required in production for magic-link and email-OTP sign-in. In development,
# if unset, email bodies are logged to the server console (see src/lib/mailer.ts).
# Create and verify a sending domain at https://www.mailgun.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=witus.online
# Leave MAILGUN_REGION unset for US accounts. Set it to "eu" only if your
# Mailgun account is in the EU region.
# MAILGUN_REGION=us
# EMAIL_FROM must be a verified sender on your Mailgun domain.
# Example: "Wanderlearn <noreply@witus.online>" or bare noreply@witus.online
EMAIL_FROM=noreply@witus.online

# ---- Admin ------------------------------------------------------------------
# Email address that receives support-chat notifications (week 11+).
ADMIN_NOTIFY_EMAIL=
